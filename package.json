{
  "name": "clarity-distribution",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:reset": "npx prisma db push --force-reset && npx tsx scripts/seed.ts",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@prisma/client": "5.20.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.0",
    "lucide-react": "^0.453.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.8",
    "react-hot-toast": "^2.4.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/bcryptjs": "^2.4.6",
    "prisma": "5.20.0",
    "tsx": "^4.19.0",
    "tailwindcss": "^3.4.13",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.15"
  }
}
