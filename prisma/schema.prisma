generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  commercial
  stock_manager
  accountant
  supervisor
}

model User {
  id                   String    @id @default(cuid())
  full_name            String
  email                String    @unique
  phone                String?
  password_hash        String
  role                 Role      @default(commercial)
  must_change_password Boolean   @default(true)
  active               Boolean   @default(true)
  last_login           DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  created_by           String?

  orders          Order[]
  activity_logs   ActivityLog[]
  stock_movements StockMovement[]
  import_sessions ImportSession[]

  @@map("users")
}

model Brand {
  id         String    @id @default(cuid())
  name       String    @unique
  active     Boolean   @default(true)
  created_at DateTime  @default(now())
  products   Product[]
  @@map("brands")
}

model Category {
  id         String    @id @default(cuid())
  name       String    @unique
  active     Boolean   @default(true)
  created_at DateTime  @default(now())
  products   Product[]
  @@map("categories")
}

model City {
  id         String   @id @default(cuid())
  name       String   @unique
  region     String?
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  orders     Order[]
  @@map("cities")
}

model ShippingCompany {
  id         String   @id @default(cuid())
  name       String   @unique
  phone      String?
  email      String?
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  created_by String?
  orders     Order[]
  @@map("shipping_companies")
}

model Product {
  id            String             @id @default(cuid())
  name          String
  image         String?
  brand_id      String
  category_id   String
  buying_price  Decimal            @db.Decimal(12, 2)
  selling_price Decimal            @db.Decimal(12, 2)
  active        Boolean            @default(true)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  created_by    String?

  brand           Brand              @relation(fields: [brand_id], references: [id])
  category        Category           @relation(fields: [category_id], references: [id])
  variations      ProductVariation[]
  order_items     OrderItem[]
  stock_movements StockMovement[]
  @@map("products")
}

model ProductVariation {
  id            String   @id @default(cuid())
  product_id    String
  name          String
  sku           String   @unique
  image         String?
  buying_price  Decimal? @db.Decimal(12, 2)
  selling_price Decimal? @db.Decimal(12, 2)
  active        Boolean  @default(true)
  created_at    DateTime @default(now())

  product         Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order_items     OrderItem[]
  stock_movements StockMovement[]
  @@map("product_variations")
}

enum MovementType {
  initial_stock
  manual_add
  manual_remove
  correction
  shipped_order
  returned_order
  import_adjustment
}

model StockMovement {
  id           String       @id @default(cuid())
  product_id   String
  variation_id String?
  type         MovementType
  quantity     Int
  reference    String?
  note         String?
  user_id      String
  created_at   DateTime     @default(now())

  product   Product           @relation(fields: [product_id], references: [id])
  variation ProductVariation? @relation(fields: [variation_id], references: [id])
  user      User              @relation(fields: [user_id], references: [id])
  @@map("stock_movements")
}

enum OrderStatus {
  new_order
  confirmed
  shipped
  delivered
  returned
  cancelled
}

enum PaymentType {
  cash
  cheque
  credit
}

enum PaymentStatus {
  unpaid
  partial
  paid
  pending
  overdue
  rejected
}

model Order {
  id                  String        @id @default(cuid())
  order_number        String        @unique
  customer_name       String
  company_name        String?
  phone               String
  city_id             String
  address             String?
  status              OrderStatus   @default(new_order)
  shipping_company_id String?
  payment_type        PaymentType   @default(cash)
  payment_status      PaymentStatus @default(unpaid)
  subtotal_ht         Decimal       @db.Decimal(12, 2) @default(0)
  tva_amount          Decimal       @db.Decimal(12, 2) @default(0)
  total_ttc           Decimal       @db.Decimal(12, 2) @default(0)
  notes               String?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  created_by          String

  city             City              @relation(fields: [city_id], references: [id])
  shipping_company ShippingCompany?  @relation(fields: [shipping_company_id], references: [id])
  user             User              @relation(fields: [created_by], references: [id])
  items            OrderItem[]
  status_history   OrderStatusHistory[]
  invoices         Invoice[]
  payments         Payment[]
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  order_id     String
  product_id   String
  variation_id String?
  quantity     Int
  unit_price   Decimal @db.Decimal(12, 2)
  discount_pct Decimal @db.Decimal(5, 2) @default(0)
  line_ht      Decimal @db.Decimal(12, 2)
  line_tva     Decimal @db.Decimal(12, 2)
  line_ttc     Decimal @db.Decimal(12, 2)

  order     Order             @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product   Product           @relation(fields: [product_id], references: [id])
  variation ProductVariation? @relation(fields: [variation_id], references: [id])
  @@map("order_items")
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  order_id   String
  old_status OrderStatus?
  new_status OrderStatus
  changed_by String
  note       String?
  created_at DateTime     @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  @@map("order_status_history")
}

enum InvoiceType {
  HT
  TTC
}

model Invoice {
  id             String      @id @default(cuid())
  invoice_number String      @unique
  type           InvoiceType
  order_id       String
  customer_name  String
  company_name   String?
  amount         Decimal     @db.Decimal(12, 2)
  snapshot_data  Json?
  pdf_url        String?
  created_at     DateTime    @default(now())
  created_by     String?

  order Order @relation(fields: [order_id], references: [id])
  @@map("invoices")
}

model InvoiceSequence {
  id          String      @id @default(cuid())
  type        InvoiceType @unique
  last_number Int         @default(0)
  @@map("invoice_sequences")
}

model Payment {
  id           String        @id @default(cuid())
  order_id     String
  amount       Decimal       @db.Decimal(12, 2)
  payment_type PaymentType
  status       PaymentStatus @default(pending)
  reference    String?
  note         String?
  created_at   DateTime      @default(now())
  created_by   String?

  order   Order    @relation(fields: [order_id], references: [id])
  cheques Cheque[]
  @@map("payments")
}

enum ChequeStatus {
  pending
  received
  deposited
  cleared
  bounced
}

model Cheque {
  id            String       @id @default(cuid())
  reference     String       @unique
  image_url     String?
  amount        Decimal      @db.Decimal(12, 2)
  issue_date    DateTime
  arrival_date  DateTime?
  deposit_date  DateTime?
  bank          String
  status        ChequeStatus @default(pending)
  customer_name String
  order_id      String?
  payment_id    String?
  note          String?
  created_at    DateTime     @default(now())
  created_by    String?

  payment Payment? @relation(fields: [payment_id], references: [id])
  @@map("cheques")
}

enum CreditStatus {
  open
  due_soon
  overdue
  settled
}

model Credit {
  id               String       @id @default(cuid())
  customer_name    String
  amount           Decimal      @db.Decimal(12, 2)
  remaining_amount Decimal      @db.Decimal(12, 2)
  due_date         DateTime
  status           CreditStatus @default(open)
  order_id         String?
  notes            String?
  created_at       DateTime     @default(now())
  created_by       String?

  credit_payments CreditPayment[]
  @@map("credits")
}

model CreditPayment {
  id         String   @id @default(cuid())
  credit_id  String
  amount     Decimal  @db.Decimal(12, 2)
  note       String?
  created_at DateTime @default(now())
  created_by String?

  credit Credit @relation(fields: [credit_id], references: [id], onDelete: Cascade)
  @@map("credit_payments")
}

model ActivityLog {
  id          String   @id @default(cuid())
  user_id     String
  action      String
  module      String
  description String
  old_data    Json?
  new_data    Json?
  ip_address  String?
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
  @@map("activity_logs")
}

enum ImportStatus {
  pending
  validating
  validated
  importing
  completed
  failed
}

model ImportSession {
  id            String       @id @default(cuid())
  filename      String
  total_rows    Int          @default(0)
  valid_rows    Int          @default(0)
  error_rows    Int          @default(0)
  imported_rows Int          @default(0)
  status        ImportStatus @default(pending)
  user_id       String
  created_at    DateTime     @default(now())

  user User        @relation(fields: [user_id], references: [id])
  rows ImportRow[]
  @@map("import_sessions")
}

model ImportRow {
  id         String   @id @default(cuid())
  session_id String
  row_number Int
  data       Json
  errors     Json?
  imported   Boolean  @default(false)
  created_at DateTime @default(now())

  session ImportSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  @@map("import_rows")
}
